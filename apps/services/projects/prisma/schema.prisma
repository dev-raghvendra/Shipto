generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectType {
  STATIC
  DYNAMIC
}

model Project {
  projectId   String    @id @default(uuid())
  name        String
  framework   String?         
  projectType ProjectType
  createdAt   DateTime?  @default(now())
  updatedAt   DateTime?  @updatedAt
  domain      String     @unique

  repository          Repository ?
  deployments           Deployment[]
  environmentVariables  EnvironmentVariable[]
}

model GithubInstallation {
  githubInstallationId String @id
  userId         String
  githubUserName String
  createdAt      DateTime? @default(now())
  updatedAt      DateTime? @updatedAt

  repositoryConfigs    RepositoryConfig[]
}

model Framework {
  frameworkId     String   @id @default(uuid())
  icon            String
  name            String   @unique
  displayName     String   @unique
  applicationType ProjectType
  defaultBuildCmd String
  defaultProdCmd  String?  @default("")
  runtime         Runtime  


  repository    Repository[]
}

model Repository {
  repositoryId      String    @id @default(uuid())
  repoName          String    @unique
  projectId         String    @unique
  productionCommand String?   @default("")
  buildCommand      String   @default("")
  frameworkId       String
  branch            String
  createdAt   DateTime?  @default(now())
  updatedAt   DateTime?  @updatedAt

  project           Project   @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  framework         Framework @relation(fields: [frameworkId], references: [frameworkId], onDelete: Cascade)
  deployments       Deployment[]
  repositoryConfigs RepositoryConfig[]
}

model RepositoryConfig {
  githubInstallationId String 
  repoURI           String    @unique
  repositoryId     String    @unique
  createdAt        DateTime? @default(now())
  updatedAt        DateTime? @updatedAt
  githubRepositoryId String  @unique
  githubWebhookId String @unique

  repository Repository @relation(fields: [repositoryId], references: [repositoryId], onDelete: Cascade)
  githubInstallation GithubInstallation @relation(fields: [githubInstallationId], references: [githubInstallationId], onDelete: Cascade)
}

model Deployment {
  deploymentId    String           @id @default(uuid())
  commitHash      String         @unique
  status          DeploymentStatus? @default(QUEUED)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  commitMessage   String
  author          String
  projectId       String
  repositoryId    String

  project         Project          @relation(fields: [projectId], references: [projectId], onDelete: Cascade)
  repository      Repository       @relation(fields: [repositoryId], references: [repositoryId], onDelete: SetNull)
}

model EnvironmentVariable {
  projectId  String
  envName    String
  envValue   String

  project    Project @relation(fields: [projectId], references: [projectId], onDelete: Cascade)

  @@id([projectId, envName])
}

enum DeploymentStatus {
  QUEUED
  INACTIVE
  FAILED
  PRODUCTION
  BUILDING
}

enum Runtime {
  NODEJS
  PYTHON
  PHP
}