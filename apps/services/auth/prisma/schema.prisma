
generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId         String    @id @default(uuid())
  fullName       String
  email          String    @unique
  password       String    @unique
  avatarUri      String    @unique
  emailVerified  Boolean   @default(false)
  createdAt      DateTime?  @default(now())
  updatedAt      DateTime?  @default(now())
  teamMembers    TeamMember[]
  provider       ProviderType 
  projectMembers ProjectMember[]
}

model Team {
  teamId      String       @id @default(uuid())
  teamName    String
  description String?
  planType    String       @default("free")
  createdAt   DateTime?     @default(now())
  updatedAt   DateTime?     @default(now())
  teamMembers TeamMember[]
  teamInvitation TeamMemberInvitation[]
}


model TeamMember {
  memberId String @id @default(uuid())
  userId   String
  teamId   String
  role     RoleType

  team   Team  @relation(fields: [teamId], references: [teamId], onDelete: Cascade)
  member User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model ProjectMember {
  userId    String
  role      RoleType
  projectId String

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([userId, projectId])
}

model TeamMemberInvitation {
  inviteId String  @id   @default(uuid())
  role     RoleType   
  teamId   String
  status   InviteStatus

  team     Team @relation(fields: [teamId],references: [teamId], onDelete: Cascade)
}

model ProjectMemberInvitation {
  inviteId    String  @id   @default(uuid())
  role        RoleType   
  projectId   String
  status      InviteStatus
}

enum PermissionType {
  READ
  UPDATE
  DELETE
  CREATE
  SELF_DELETE
  SELF_UPDATE
}

enum ProviderType {
  GOOGLE
  GITHUB
  EMAIL
}

enum RoleType {
  OWNER
  DEVELOPER
  ADMIN
  VIEWER
}

enum ScopeType {
  PROJECT
  TEAM
  DEPLOYMENT
  TEAM_MEMBER
  PROJECT_MEMBER
}

enum InviteStatus {
  ACCEPTED
  PENDING
}