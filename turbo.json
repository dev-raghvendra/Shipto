{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/generated/**",
        "!**/.prisma/**"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/generated/**",
        "!**/.prisma/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate":{
       "dependsOn": ["^generate"],
       "inputs":["$TURBO_DEFAULT$",".prisma*",".proto*"]
    }
  }
}
